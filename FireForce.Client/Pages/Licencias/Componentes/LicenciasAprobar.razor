    .licencias-aprobar .reject-button:hover {
    color: white !important;
    background: var(--apr-error-color) !important;
    transform: scale(1.1) !important;
    box-shadow: 0 4px 12px rgba(198, 40, 40, 0.3) !important;
    }

    .licencias-aprobar .status-badge {
    padding: 4px 10px !important;
    border-radius: 12px !important;
    font-weight: 600 !important;
    font-size: 0.8rem !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
    background: var(--apr-warning-light) !important;
    color: var(--apr-warning-color) !important;
    display: inline-flex !important;
    align-items: center !important;
