    font-size: 0.8rem !important;
    }

    .licencias-aprobar .action-buttons {
    gap: 8px !important;
    }

    .licencias-aprobar .approve-button,
    .licencias-aprobar .reject-button {
    width: 32px !important;
    height: 32px !important;
    font-size: 1rem !important;
    }
    /* Hide less important columns on mobile */
    .licencias-aprobar :deep(.ant-table-cell:nth-child(3)),
    .licencias-aprobar :deep(.ant-table-cell:nth-child(4)) {
    display: none !important;
    }
    }

    @@media (max-width: 480px) {
    .licencias-aprobar .approval-content {
    max-height: 50vh !important;
    }

    .licencias-aprobar :deep(.ant-table-cell:nth-child(5)) {
