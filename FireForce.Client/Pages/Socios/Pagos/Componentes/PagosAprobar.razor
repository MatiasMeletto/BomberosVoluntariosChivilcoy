    }

    .modal-rechazar-pago .pago-info-item:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transform: translateY(-1px);
    border: 2px solid #A63333;
    }

    .modal-rechazar-pago .pago-info-label {
    font-size: 0.8rem;
    color: #666;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
    display: block;
    }

    .modal-rechazar-pago .pago-info-value {
    font-size: 0.95rem;
    color: #333;
    font-weight: 500;
    word-break: break-word;
    }

    .modal-rechazar-pago .reason-form-item {
    margin-bottom: 16px;
    }

    .modal-rechazar-pago .reason-form-item .ant-form-item-label > label {
    font-weight: 600;
    color: var(--apr-error-color);
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1rem;
    }

    .modal-rechazar-pago .reason-textarea {
    border-radius: 8px !important;
    border: 2px solid #d9d9d9 !important;
    transition: all 0.3s ease !important;
    }

    .modal-rechazar-pago .reason-textarea:focus,
    .modal-rechazar-pago .reason-textarea:hover {
    border-color: #A63333 !important;
    box-shadow: 0 0 0 2px rgba(166, 51, 51, 0.1) !important;
    }

    .modal-rechazar-pago .button-row-right {
    display: flex !important;
    width: 100% !important;
    margin-top: 20px !important;
    }

    .modal-rechazar-pago .button-container-right {
    display: flex !important;
    gap: 12px !important;
    margin-left: auto !important;
    }

    .modal-rechazar-pago .btn-confirm-reject {
    background: linear-gradient(135deg, #4CAF50 0%, #438E46 100%) !important;
    border: none !important;
    color: white !important;
    font-weight: 600;
    padding: 0 24px !important;
    height: 40px !important;
    border-radius: 8px !important;
    box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
    }

    .modal-rechazar-pago .btn-confirm-reject:hover {
    background: linear-gradient(135deg, #438E46 0%, #4CAF50 100%) !important;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(76, 175, 80, 0.4);
    }

    .modal-rechazar-pago .btn-cancel-reject {
    background: #f5f5f5 !important;
    border: 1px solid #d9d9d9 !important;
    color: #666 !important;
    font-weight: 500;
    padding: 0 20px !important;
    height: 40px !important;
    border-radius: 8px !important;
    }

    .modal-rechazar-pago .btn-cancel-reject:hover {
    background: #e6f7ff !important;
    border-color: #1890ff !important;
    color: #1890ff !important;
    }
</style>

<div class="pagos-aprobar">
    <div class="approval-container">
        <div class="approval-header">
            <h3 class="approval-title">
               <h4 style="color: white;"> 📄Pagos Pendientes de Aprobación </h4> 
                @if (PagosPendientes.Any())
                {
                    <Badge Count="@PagosPendientes.Count"
                    Style="background: var(--apr-gold-color); color: var(--apr-primary-color); font-weight: bold;" />
                }
            </h3>
        </div>

        <div class="approval-content">
            @if (_loading)
            {
                <div class="loading-container">
                    <Spin Size="SpinSize.Large" />
                    <span>Cargando pagos pendientes...</span>
                </div>
            }
            else if (!PagosPendientes.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">✅</div>
                    <div class="empty-title">¡Todo al día!</div>
                    <div class="empty-description">
                        No hay pagos pendientes de aprobación en este momento.
                    </div>
                </div>
            }
            else
            {
                <Table DataSource="PagosPendientes"
                Bordered
                Responsive
                Size="TableSize.Small"
                PageSize="5"
                HidePagination="@(PagosPendientes.Count > 5)"
                ScrollX="600px">

                    <ColumnDefinitions Context="pago">
                        <PropertyColumn Title="👤 Socio"
                        Property="c => c.NombreSocio"
                        Width="200px"
                        Fixed="ColumnFixPlacement.Left">
                            <Template>
                                <div style="font-weight: 600; color: #333;">
                                    @pago.NombreSocio
                                </div>
                                <div style="font-size: 0.8rem; color: #666;">
                                    Nro Socio: @pago.NumeroSocio
                                </div>
                            </Template>
                        </PropertyColumn>

                        <PropertyColumn Title="📅 Fecha"
                        Property="c => c.Fecha"
                        Format="dd/MM/yyyy"
                        Width="100px">
                            <Template>
                                <Tag Color="TagColor.Processing" Style="font-size: 0.75rem;">
                                    @pago.Fecha.ToString("dd/MM/yy")
                                </Tag>
                            </Template>
                        </PropertyColumn>

                        <PropertyColumn Title="💵 Monto"
                        Property="c => c.Monto"
                        Width="100px">
                            <Template>
                                <div style="text-align: right; font-weight: 600; color: var(--apr-approved-color);">
                                    @pago.Monto.ToString("C2")
                                </div>
                            </Template>
                        </PropertyColumn>

                        <PropertyColumn Title="🏷️ Tipo"
                        Property="c => c.Tipo"
                        Width="120px">
                            <Template>
                                <div style="font-size: 0.85rem; color: #333;">
                                    @pago.Tipo.ToString()
                                </div>
                            </Template>
                        </PropertyColumn>

                        <PropertyColumn Title="📊 Estado"
                        Property="c => c.Estado"
                        Width="100px">
                            <Template>
                                <div class="status-badge">
                                    <Icon Type="clock-circle" />
                                    Pendiente
                                </div>
                            </Template>
                        </PropertyColumn>

                        <ActionColumn Title="⚙️ Acciones"
                        Fixed="ColumnFixPlacement.Right"
                        Width="120px">
                            <Template>
                                <div class="action-buttons">
                                    <Tooltip Title="Aprobar pago">
                                        <Popconfirm Title="¿Confirma que desea aprobar este pago?"
                                        OnConfirm="() => AprobarPago(pago.Id)"
                                        OkText="✅ Aprobar"
                                        CancelText="❌ Cancelar"
                                        Icon="@IconType.Outline.CheckCircle">
                                            <div class="approve-button">
                                                <Icon Type="check" />
                                            </div>
                                        </Popconfirm>
                                    </Tooltip>

                                    <Tooltip Title="Rechazar pago">
                                        <div class="reject-button" @onclick="() => MostrarModalRechazo(pago)">
                                            <Icon Type="close" />
                                        </div>
                                    </Tooltip>
                                </div>
                            </Template>
                        </ActionColumn>
                    </ColumnDefinitions>
                </Table>
            }
        </div>
    </div>
</div>

@* Modal para rechazar pago con motivo *@
<Modal @bind-Visible="_modalRechazoVisible"
Title="❌ Rechazar Pago"
Width="@("90%")"
Style="max-width: 900px;"
Footer="null"
DestroyOnClose
WrapClassName="modal-rechazar-pago">

    <div class="modal-rechazo-content">
        @if (_pagoParaRechazar != null)
        {
            <div class="pago-info-card">
                <div class="pago-info-title">
                    📋 Información del Pago a Rechazar
                </div>

                <Row Gutter="12">
                    <AntDesign.Col Xs="24" Sm="12" Md="8">
                        <div class="pago-info-item">
                            <span class="pago-info-label">👤 Socio</span>
                            <div class="pago-info-value">@_pagoParaRechazar.NombreSocio</div>
                        </div>
                    </AntDesign.Col>

                    <AntDesign.Col Xs="12" Sm="12" Md="8">
                        <div class="pago-info-item">
                            <span class="pago-info-label">📋 Nro Socio</span>
                            <div class="pago-info-value">@_pagoParaRechazar.NumeroSocio</div>
                        </div>
                    </AntDesign.Col>

                    <AntDesign.Col Xs="24" Sm="12" Md="8">
                        <div class="pago-info-item">
                            <span class="pago-info-label">🏷️ Tipo</span>
                            <div class="pago-info-value">@_pagoParaRechazar.Tipo.ToString()</div>
                        </div>
                    </AntDesign.Col>

                    <AntDesign.Col Xs="12" Sm="12" Md="8">
                        <div class="pago-info-item">
                            <span class="pago-info-label">💵 Monto</span>
                            <div class="pago-info-value">@_pagoParaRechazar.Monto.ToString("C2")</div>
                        </div>
                    </AntDesign.Col>

                    <AntDesign.Col Xs="12" Sm="12" Md="8">
                        <div class="pago-info-item">
                            <span class="pago-info-label">📅 Fecha</span>
                            <div class="pago-info-value">@_pagoParaRechazar.Fecha.ToString("dd/MM/yyyy")</div>
                        </div>
                    </AntDesign.Col>
                </Row>
            </div>

            <Form Model="_pagoParaRechazar" Layout="FormLayout.Vertical">
                <FormItem Label="📝 Motivo del Rechazo" Required Class="reason-form-item">
                    <TextArea @bind-Value="_pagoParaRechazar.RazonRechazo"
                    Placeholder="Ingrese el motivo detallado por el cual se rechaza este pago..."
                    Rows="4"
                    ShowCounts
                    MaxLength="500"
                    Class="reason-textarea" />
                    <div style="margin-top: 8px; color: #666; font-size: 0.9rem;">
                        💡 Proporcione una explicación clara para que el socio comprenda la razón del rechazo de su pago.
                    </div>
                </FormItem>
            </Form>

            <Row Gutter="12" Class="button-row-right">
                <div class="button-container-right">
                    <Button Class="btn-confirm-reject"
                    OnClick="ConfirmarRechazo"
                    Disabled="@(string.IsNullOrWhiteSpace(_pagoParaRechazar.RazonRechazo))"
                    Loading="_procesandoRechazo">
                        ✅ Confirmar Rechazo
                    </Button>

                    <Button Class="btn-cancel-reject"
                    OnClick="CerrarModalRechazo">
                        ↩️ Cancelar
                    </Button>
                </div>
            </Row>
        }
    </div>
</Modal>

@code {
    [Parameter, EditorRequired] public EventCallback OnCompleted { get; set; }

    private List<PagoViewModel> PagosPendientes = new();

    private bool _loading = false;
    private bool _modalRechazoVisible = false;
    private PagoViewModel? _pagoParaRechazar;
    private bool _procesandoRechazo = false;

    protected override async Task OnInitializedAsync()
    {
        await Init();
    }

    private async Task Init()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var pagos = await PagoService.ObtenerPagosPorEstadoAsync(EstadoPago.PendienteAConfirmar);
            PagosPendientes = pagos
                .OrderBy(p => p.Fecha)
                .Select(MapToViewModel)
                .ToList();
        }
        catch (Exception ex)
        {
            await message.ErrorAsync($"Error al cargar los pagos: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task AprobarPago(int IdPago)
    {
        try
        {
            await PagoService.CambiarEstadoPago(IdPago, EstadoPago.Confirmado, null);
            await Init();
            await message.SuccessAsync("✅ ¡Pago aprobado exitosamente!");
            await OnCompleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            await message.ErrorAsync($"❌ Error al aprobar el pago: {ex.Message}");
        }
    }

    private void MostrarModalRechazo(PagoViewModel pago)
    {
        _pagoParaRechazar = pago;
        _pagoParaRechazar.RazonRechazo = ""; // Limpiar motivo previo si hubiese
        _modalRechazoVisible = true;
    }

    private void CerrarModalRechazo()
    {
        _modalRechazoVisible = false;
        _pagoParaRechazar = null;
    }

    private async Task ConfirmarRechazo()
    {
        if (_pagoParaRechazar == null || string.IsNullOrWhiteSpace(_pagoParaRechazar.RazonRechazo))
        {
            await message.ErrorAsync("⚠️ Debe ingresar un motivo para rechazar el pago.");
            return;
        }

        _procesandoRechazo = true;
        StateHasChanged();

        try
        {
            await PagoService.CambiarEstadoPago(_pagoParaRechazar.Id, EstadoPago.Rechazado, _pagoParaRechazar.RazonRechazo);
            await message.WarningAsync($"⚠️ Pago rechazado correctamente.");
            
            CerrarModalRechazo();
            await Init();
            await OnCompleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            await message.ErrorAsync($"❌ Error al rechazar el pago: {ex.Message}");
        }
        finally
        {
            _procesandoRechazo = false;
            StateHasChanged();
        }
    }

    private static PagoViewModel MapToViewModel(PagoSocio pago)
    {
        return new PagoViewModel
        {
            Id = pago.Id,
            SocioId = pago.SocioId,
            NombreSocio = pago.Socio is null ? "Sin Socio" : $"{pago.Socio.Nombre} {pago.Socio.Apellido}".Trim(),
            NumeroSocio = pago.Socio?.NroSocio ?? 0,
            Fecha = pago.Fecha,
            FechaConfirmadoORechazado = pago.FechaConfirmadoORechazado,
            RazonRechazo = pago.RazonRechazo,
            Monto = pago.Monto,
            Tipo = pago.Tipo,
            Estado = pago.Estado,
            CobradorId = pago is PagoEfectivo pe ? pe.CobradorId : 0,
            NombreCobrador = pago is PagoEfectivo pe2 && pe2.Cobrador is not null
                ? $"{pe2.Cobrador.Nombre} {pe2.Cobrador.Apellido}".Trim()
                : null,
            Observaciones = pago is PagoEfectivo pe3 ? pe3.Observaciones : null
        };
    }
}}