    margin: 0 !important;
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    }

    .pagos-aprobar .approval-content {
    padding: 0 !important;
    max-height: 70vh !important;
    overflow-y: auto !important;
    }

    .pagos-aprobar .empty-state {
