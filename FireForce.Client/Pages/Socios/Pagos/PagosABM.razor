@code {
    // Variables de búsqueda
    DateTime FechaBuscarI = DateTime.Now.AddDays(-30);
    DateTime FechaBuscarF = DateTime.Now.AddDays(30);
    string? Busqueda;
    bool _loading = false;
    private bool isLoadingComponent = false;

    // Listas
    List<PagoViewModel> PagosOriginales = new();
    List<PagoViewModel> PagosFiltrados = new();
    List<Socio> SociosList = new();
    List<Cobrador> CobradoresList = new();

    int PagosPendientesAprobacion => PagosOriginales.Count(p => p.Estado == EstadoPago.PendienteAConfirmar);

    // Modal forms
    private bool _modalAñadirVisible = false;
    private bool _modalImprimirVisible = false;
    private bool _modalParametrosCobranzaVisible = false;
    private bool _modalParametrosBonosVisible = false;
    private Zona? selectedPrintZona = null;
    private int selectedAnio = DateTime.Now.Year;
    private Zona? selectedBonosZona = null;
    private int selectedBonosMes = DateTime.Now.Month;
    private int selectedBonosAnio = DateTime.Now.Year;
    private bool _modalDetalleVisible = false;
    private PagoViewModel? pagoSeleccionado;

    private PagoViewModel nuevoPago = new()
    {
        Fecha = DateTime.Today,
        Tipo = TipoPagoSocio.Efectivo,
        Estado = EstadoPago.PendienteAConfirmar
    };

    private Dictionary<string, object> OnRowClick(RowData<PagoViewModel> rowData)
    {
        return new Dictionary<string, object>
        {
            ["onclick"] = Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, () => MostrarDetallePago(rowData.Data))
        };
    }

    private void MostrarDetallePago(PagoViewModel pago)
    {
        pagoSeleccionado = pago;
        _modalDetalleVisible = true;
    }

    protected override async Task OnInitializedAsync()
    {
        await Init();
    }

    private async Task Init()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var pagos = await PagoService.ObtenerTodosLosPagosAsync();
            PagosOriginales = pagos.Select(MapToViewModel).ToList();
            SociosList = await SocioService.ObtenerSociosAsync() ?? new List<Socio>();
            CobradoresList = (await CobradorService.ObtenerTodosLosCobradoresAsync()).ToList();

            PagosFiltrados = FiltrarPagos();
        }
        catch (Exception ex)
        {
            await MessageService.ErrorAsync($"❌ Error al cargar los datos: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private List<PagoViewModel> FiltrarPagos()
    {
        var filtered = PagosOriginales
            .Where(p => (FechaBuscarI == default || p.Fecha.Date >= FechaBuscarI.Date) &&
                        (FechaBuscarF == default || p.Fecha.Date <= FechaBuscarF.Date) &&
                        (string.IsNullOrWhiteSpace(Busqueda) ||
                            p.NombreSocio.Contains(Busqueda, StringComparison.OrdinalIgnoreCase) ||
                            p.NumeroSocio.ToString().Contains(Busqueda)))
            .OrderByDescending(p => p.Fecha)
            .ToList();

        return filtered;
    }

    private async Task AddPago()
    {
        isLoadingComponent = true;

        if (nuevoPago.SocioId <= 0 || nuevoPago.Monto <= 0 || nuevoPago.CobradorId <= 0)
        {
            await MessageService.ErrorAsync("⚠️ Por favor, complete todos los campos obligatorios.");
            isLoadingComponent = false;
            return;
        }

        try
        {
            var nuevopago = new PagoEfectivo
            {
                SocioId = nuevoPago.SocioId,
                CobradorId = nuevoPago.CobradorId,
                Monto = nuevoPago.Monto,
                Fecha = nuevoPago.Fecha,
                Estado = EstadoPago.PendienteAConfirmar,
                Tipo = TipoPagoSocio.Efectivo,
                Observaciones = nuevoPago.Observaciones
            };

            await PagoService.AgregarPagoAsync(nuevoPago.SocioId, nuevopago);
            await MessageService.SuccessAsync("✅ Pago registrado exitosamente y enviado para confirmación.");
            
            _modalAñadirVisible = false;
            nuevoPago = new PagoViewModel
            {
                Fecha = DateTime.Today,
                Tipo = TipoPagoSocio.Efectivo,
                Estado = EstadoPago.PendienteAConfirmar
            };

            await Init();
        }
        catch (Exception ex)
        {
            await MessageService.ErrorAsync($"❌ Error al registrar el pago: {ex.Message}");
        }
        finally
        {
            isLoadingComponent = false;
        }
    }

    private async Task ImprimirBonos()
    {
        _modalParametrosBonosVisible = true;
        _modalImprimirVisible = false;
        await Task.CompletedTask;
    }

    private void ImprimirListaCobranza()
    {
        _modalImprimirVisible = false;
        _modalParametrosCobranzaVisible = true;
    }

    private IEnumerable<Zona> GetZonasDisponibles()
    {
        return new[] { Zona.Zona1, Zona.Zona2, Zona.Zona3, Zona.Zona4, Zona.Zona5 };
    }

    private void SelectPrintZona(Zona? zona)
    {
        selectedPrintZona = zona;
    }

    private void SelectBonosZona(Zona? zona)
    {
        selectedBonosZona = zona;
    }

    private static int ObtenerNumeroZona(Zona? zona)
    {
        return zona switch
        {
            Zona.Zona1 => 1,
            Zona.Zona2 => 2,
            Zona.Zona3 => 3,
            Zona.Zona4 => 4,
            Zona.Zona5 => 5,
            _ => 0
        };
    }

    private void ConfirmPrintCobranza()
    {
        int zonaParam = ObtenerNumeroZona(selectedPrintZona);
        string url = $"/fire-force/socios/imprimibles/lista-cobranza-anual/{selectedAnio}/{zonaParam}";

        navigationManager.NavigateTo(url, forceLoad: true);
        _modalParametrosCobranzaVisible = false;
    }

    private void ConfirmPrintBonos()
    {
        int zonaParam = ObtenerNumeroZona(selectedBonosZona);
        string url = $"/fire-force/socios/imprimibles/bonos/{zonaParam}/{selectedBonosMes}/{selectedBonosAnio}";

        navigationManager.NavigateTo(url, forceLoad: true);
        _modalParametrosBonosVisible = false;
    }

    private static PagoViewModel MapToViewModel(PagoSocio pago)
    {
        return new PagoViewModel
        {
            Id = pago.Id,
            SocioId = pago.SocioId,
            NombreSocio = pago.Socio is null ? "Sin Socio" : $"{pago.Socio.Nombre} {pago.Socio.Apellido}".Trim(),
            NumeroSocio = pago.Socio?.NroSocio ?? 0,
            Fecha = pago.Fecha,
            FechaConfirmadoORechazado = pago.FechaConfirmadoORechazado,
            RazonRechazo = pago.RazonRechazo,
            Monto = pago.Monto,
            Tipo = pago.Tipo,
            Estado = pago.Estado,
            CobradorId = pago is PagoEfectivo pe ? pe.CobradorId : 0,
            NombreCobrador = pago is PagoEfectivo pe2 && pe2.Cobrador is not null
                ? $"{pe2.Cobrador.Nombre} {pe2.Cobrador.Apellido}".Trim()
                : null,
            Observaciones = pago is PagoEfectivo pe3 ? pe3.Observaciones : null
        };
    }
}