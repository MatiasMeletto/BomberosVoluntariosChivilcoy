<div class="pagos-abm">
    <div class="licenses-container fade-in">
        <Card Class="main-card">
            <div class="header-section">
                <div class="lava-bubbles">
                    <div class="lava-bubble b1"></div>
                    <div class="lava-bubble b2"></div>
                    <div class="lava-bubble b3"></div>
                    <div class="lava-bubble b4"></div>
                    <div class="lava-bubble b5"></div>
                </div>
                <div class="title-container">
                    <h1 class="main-title">
                        <Icon Type="dollar" Class="title-icon" />
                        PAGOS
                    </h1>
                </div>
                <div class="filters-section">
                    <div class="filter-row">
                        <div class="filter-group">
                            <label class="filter-label">📅 Fecha Desde</label>
                            <DatePicker Mask="dd/MM/yyyy" TValue="DateTime"
                                        DefaultValue="@DateTime.Now.AddDays(-30)"
                                        @bind-Value="@FechaBuscarI"
                                        Size="InputSize.Large"
                                        Placeholder="@("Seleccionar fecha")" />
                        </div>
                        <div class="filter-group">
                            <label class="filter-label">📅 Fecha Hasta</label>
                            <DatePicker Mask="dd/MM/yyyy" TValue="DateTime"
                                        DefaultValue="@DateTime.Now.AddDays(30)"
                                        @bind-Value="@FechaBuscarF"
                                        Size="InputSize.Large"
                                        Placeholder="@("Seleccionar fecha")" />
                        </div>
                    </div>

                    <div class="actions-row">
                        <div class="search-container">
                            <Search Placeholder="🔍 Buscar por nombre de socio o nro..."
                                    AllowClear
                                    EnterButton="true"
                                    Size="InputSize.Large"
                                    OnSearch="@(() => PagosFiltrados = FiltrarPagos())"
                                    @bind-Value="Busqueda" />
                        </div>

                        <Button Class="modern-button add-button"
                                OnClick="@(() => _modalAñadirVisible = true)"
                                Icon="plus"
                                Size="ButtonSize.Large">
                            Nuevo Pago
                        </Button>

                        <Button Class="modern-button print-button"
                                OnClick="@(() => _modalImprimirVisible = true)"
                                Icon="printer"
                                Size="ButtonSize.Large">
                            Imprimir
                        </Button>

                        <Dropdown Trigger="@(new Trigger[] { Trigger.Click })"
                                  Placement="Placement.BottomRight"
                                  Arrow>
                            <Overlay>
                                <div style="min-width: 520px; max-width: 90vw;">
                                    <PagosAprobar OnCompleted="@Init" />
                                </div>
                            </Overlay>
                            <ChildContent>
                                <Badge Count="@PagosPendientesAprobacion" ShowZero="false">
                                    <Button Class="notification-button" Shape="ButtonShape.Circle" Size="ButtonSize.Large">
                                        <Icon Type="bell" />
                                    </Button>
                                </Badge>
                            </ChildContent>
                        </Dropdown>
                    </div>
                </div>
            </div>

            <div class="table-container">
                <Table DataSource="PagosFiltrados"
                       HidePagination="false"
                       Responsive
                       TItem="PagoViewModel"
                       RowClassName="@(c => c.Data.Estado.ToString())"
                       OnRow="@OnRowClick"
                       Loading="@_loading"
                       ScrollX="800px">

                    <ColumnDefinitions Context="pago">
                        <PropertyColumn Title="👤 Socio"
                                        Property="c => c.NombreSocio"
                                        Sortable
                                        Width="250px"
                                        Fixed="ColumnFixPlacement.Left">
                            <Template>
                                <div style="font-weight: 600; color: #333;">
                                    @pago.NombreSocio
                                </div>
                                <div style="font-size: 0.8rem; color: #666;">
                                    Nro Socio: @pago.NumeroSocio
                                </div>
                            </Template>
                        </PropertyColumn>

                        <PropertyColumn Title="📅 Fecha"
                                        Property="c => c.Fecha"
                                        Format="dd/MM/yyyy"
                                        Sortable
                                        DefaultSortOrder="SortDirection.Descending"
                                        Width="120px" />

                        <PropertyColumn Title="💵 Monto"
                                        Property="c => c.Monto"
                                        Sortable
                                        Width="120px">
                            <Template>
                                <Tag Color="TagColor.Processing" Style="font-size: 0.95rem; font-weight: 600;">
                                    @pago.Monto.ToString("C2")
                                </Tag>
                            </Template>
                        </PropertyColumn>

                        <PropertyColumn Title="🏷️ Tipo"
                                        Property="c => c.Tipo.ToString()"
                                        Sortable
                                        Width="150px" />

                        <PropertyColumn Title="📊 Estado"
                                        Property="c => c.Estado"
                                        Sortable
                                        Width="150px"
                                        Fixed="ColumnFixPlacement.Right">
                            <Template>
                                @{
                                    string statusClass = pago.Estado switch
                                    {
                                        EstadoPago.Rechazado => "status-rejected",
                                        EstadoPago.Confirmado => "status-approved",
                                        _ => "status-pending"
                                    };
                                    string icon = pago.Estado switch
                                    {
                                        EstadoPago.Rechazado => "close-circle",
                                        EstadoPago.Confirmado => "check-circle",
                                        _ => "clock-circle"
                                    };
                                }
                                <Space>
                                    <Icon Type="@icon" />
                                    <span class="status-badge @statusClass">
                                        @pago.Estado.ToString()
                                    </span>
                                </Space>
                            </Template>
                        </PropertyColumn>
                    </ColumnDefinitions>
                </Table>
            </div>
        </Card>
    </div>
</div>

