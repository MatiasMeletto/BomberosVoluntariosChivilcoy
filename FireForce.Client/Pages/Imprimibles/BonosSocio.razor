@layout EmptyLayout

@page "/fire-force/socios/imprimibles/bonos/{ZonaParam:int}/{Mes:int}"
@page "/fire-force/socios/imprimibles/bonos/{ZonaParam:int}/{Mes:int}/{Anio:int}"

@using System.Globalization
@using FireForce.Shared.Enums.Discriminadores
@using FireForce.Shared.Enums.Socios
@using FireForce.Data.Models.Socios
@using FireForce.Client.Services
@using Microsoft.JSInterop

@inject ISocioService SocioService
@inject IJSRuntime JSRuntime

<PageTitle>Bonos de Socios - Bomberos Voluntarios de Chivilcoy</PageTitle>

<style>
    :root {
        --black: #000;
        --border: #2f2f2f;
        --light: #f4f4f4;
        --white: #fff;
    }

    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: var(--white);
        color: var(--black);
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }

    #pdf-content {
        width: 100%;
        max-width: 210mm;
        margin: 0 auto;
        padding: 8mm;
        box-sizing: border-box;
    }

    .sheet-header {
        margin-bottom: 5mm;
        border-bottom: 2px solid var(--black);
        padding-bottom: 3mm;
        display: flex;
        justify-content: space-between;
        font-size: 10pt;
    }

    .sheet-title {
        font-weight: 700;
        font-size: 12pt;
    }

    .bonos-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 4mm;
    }

    .bono {
        border: 1.3px solid var(--black);
        min-height: 82mm;
        display: flex;
        position: relative;
        overflow: hidden;
        background: var(--white);
        page-break-inside: avoid;
    }

    .logo-fondo {
        position: absolute;
        top: 50%;
        left: 62%;
        transform: translate(-50%, -50%);
        width: 45mm;
        opacity: 0.12;
        pointer-events: none;
    }

    .bono-lateral {
        width: 21mm;
        border-right: 1px dashed var(--black);
        position: relative;
        padding: 2.5mm 1mm;
        z-index: 1;
    }

    .lateral-superior {
        writing-mode: vertical-rl;
        transform: translateX(-50%) rotate(180deg);
        position: absolute;
        top: 2.5mm;
        left: 50%;
        font-size: 9.5pt;
        font-weight: 700;
    }

    .lateral-textos {
        writing-mode: vertical-rl;
        transform: translateX(-50%) rotate(180deg);
        position: absolute;
        bottom: 2.5mm;
        left: 50%;
        font-size: 8.7pt;
        font-weight: 700;
        display: flex;
        flex-direction: column;
        gap: 1.8mm;
        text-align: center;
    }

    .bono-cuerpo {
        flex: 1;
        padding: 3mm;
        z-index: 1;
        display: flex;
        flex-direction: column;
    }

    .bono-header {
        text-align: center;
        margin-bottom: 2.5mm;
    }

    .bono-header h3 {
        margin: 0;
        font-size: 9.7pt;
        line-height: 1.2;
        letter-spacing: 0.3px;
    }

    .bono-header p {
        margin: 1mm 0 0;
        font-size: 7.6pt;
    }

    .datos {
        border: 1px solid var(--black);
        font-size: 8.6pt;
    }

    .fila {
        display: flex;
        border-bottom: 1px solid var(--border);
    }

    .fila:last-child {
        border-bottom: none;
    }

    .fila-mitad .fila-valor {
        display: flex;
        padding: 0;
    }

    .fila-mitad-item {
        flex: 1;
        padding: 1.4mm 1.7mm;
        font-weight: 700;
    }

    .fila-mitad-item:first-child {
        border-right: 1px solid var(--border);
    }

    .fila-label {
        width: 33%;
        padding: 1.4mm 1.7mm;
        font-weight: 700;
        border-right: 1px solid var(--border);
        background: var(--light);
    }

    .fila-valor {
        flex: 1;
        padding: 1.4mm 1.7mm;
    }

    .total {
        margin-top: auto;
        font-weight: 700;
        font-size: 11pt;
        text-align: right;
        padding-top: 2mm;
    }

    .action-buttons {
        position: fixed;
        bottom: 20px;
        right: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 1000;
    }

    .action-button {
        background: var(--black);
        color: var(--white);
        border: none;
        padding: 10px 14px;
        font-size: 9pt;
        cursor: pointer;
    }

    .action-button.secondary {
        background: var(--white);
        color: var(--black);
        border: 1px solid var(--black);
    }

    .action-button:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .loading-container,
    .no-data {
        min-height: 280px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-size: 12pt;
    }

    @@media print {
        @@page {
            size: A4 portrait;
            margin: 5mm;
        }

        #pdf-content {
            max-width: 100%;
            padding: 0;
        }

        .action-buttons {
            display: none !important;
        }
    }
</style>

@if (IsLoading)
{
    <div class="loading-container">
        <p>Cargando bonos...</p>
    </div>
}
else if (!Bonos.Any())
{
    <div class="no-data">
        <div>
            <h3>No hay bonos para imprimir</h3>
            <p>Zona @ZonaTexto - @MesTexto/@AnioSeleccionado</p>
        </div>
    </div>
}
else
{
    <div id="pdf-content">
        <div class="sheet-header">
            <div>
                <div class="sheet-title">Bonos de Socios</div>
                <div>Bomberos Voluntarios de Chivilcoy</div>
            </div>
            <div>
                <div><strong>Zona:</strong> @ZonaTexto</div>
                <div><strong>Mes:</strong> @MesTexto</div>
                <div><strong>Año:</strong> @AnioSeleccionado</div>
                <div><strong>Emitido:</strong> @FechaHoraArgentina.ToString("dd/MM/yyyy HH:mm") hs</div>
            </div>
        </div>

        <div class="bonos-grid">
            @foreach (var bono in Bonos)
            {
                <article class="bono">
                    <img src="/Imagenes/Logo.svg" alt="Logo Bomberos" class="logo-fondo" />

                    <div class="bono-lateral">
                        <div class="lateral-textos">
                            <div>SOCIO: @bono.NombreSocio - N°: @bono.NroSocio</div>
                            <div>DIRECCIÓN: @bono.Direccion</div>
                            <div>TOTAL: @bono.MontoCuotaTexto</div>
                        </div>
                    </div>

                    <div class="bono-cuerpo">
                        <div class="bono-header">
                            <h3>SOCIEDAD DE BOMBEROS<br />VOLUNTARIOS DE CHIVILCOY</h3>
                            <p>Tel: 02346-424319 / 436066</p>
                        </div>

                        <div class="datos">
                            <div class="fila">
                                <div class="fila-label">SOCIO</div>
                                <div class="fila-valor">@bono.NombreSocio</div>
                            </div>
                            <div class="fila">
                                <div class="fila-label">N°</div>
                                <div class="fila-valor">@bono.NroSocio</div>
                            </div>
                            <div class="fila">
                                <div class="fila-label">DIRECCIÓN</div>
                                <div class="fila-valor">@bono.Direccion</div>
                            </div>
                            <div class="fila">
                                <div class="fila-label">FORMA DE PAGO</div>
                                <div class="fila-valor">@bono.FrecuenciaPagoTexto @Mes/@AnioSeleccionado</div>
                            </div>
                            <div class="fila">
                                <div class="fila-label">ZONA</div>
                                <div class="fila-valor">@bono.ZonaTexto</div>
                            </div>
                        </div>

                        <div class="total">TOTAL: @bono.MontoCuotaTexto</div>
                    </div>
                </article>
            }
        </div>
    </div>

    <div class="action-buttons">
        <button class="action-button" @onclick="DescargarPdf" disabled="@IsGenerating">
            @(IsGenerating ? "Generando..." : "Descargar PDF")
        </button>
        <button class="action-button secondary" @onclick="VistaPrevia" disabled="@IsGenerating">
            Vista previa
        </button>
    </div>
}

@code {
    [Parameter]
    public int ZonaParam { get; set; }

    [Parameter]
    public int Mes { get; set; }

    [Parameter]
    public int? Anio { get; set; }

    private bool IsLoading { get; set; } = true;
    private bool IsGenerating { get; set; }
    private DateTime FechaHoraArgentina { get; set; }
    private string ZonaTexto { get; set; } = "-";
    private string MesTexto { get; set; } = "-";
    private int AnioSeleccionado { get; set; }
    private List<BonoImprimible> Bonos { get; set; } = new();

    private sealed class BonoImprimible
    {
        public int NroSocio { get; set; }
        public string NombreSocio { get; set; } = string.Empty;
        public string Direccion { get; set; } = string.Empty;
        public string ZonaTexto { get; set; } = string.Empty;
        public string FrecuenciaPagoTexto { get; set; } = string.Empty;
        public string MontoCuotaTexto { get; set; } = "$0";
    }

    protected override async Task OnInitializedAsync()
    {
        FechaHoraArgentina = ObtenerFechaArgentina();
        await CargarBonos();
    }

    private async Task CargarBonos()
    {
        IsLoading = true;

        try
        {
            var zonaFiltro = ConvertirZonaParametro(ZonaParam);
            ZonaTexto = ObtenerZonaTexto(zonaFiltro);
            MesTexto = ObtenerNombreMes(Mes);
            AnioSeleccionado = Anio is >= 1900 and <= 3000 ? Anio.Value : FechaHoraArgentina.Year;

            if (zonaFiltro == Zona.Ninguna || Mes is < 1 or > 12)
            {
                Bonos = new List<BonoImprimible>();
                return;
            }

            var socios = await SocioService.ObtenerSociosAsync() ?? new List<Socio>();

            Bonos = socios
                .Where(s => s.EstadoSocio != TipoEstadoSocio.Inactivo)
                .Where(s => s.Zona.HasValue && s.Zona.Value.HasFlag(zonaFiltro))
                .Where(s => DebeEmitirBono(s.FrecuenciaDePago, Mes))
                .OrderBy(s => s.NroSocio)
                .Select(s => new BonoImprimible
                {
                    NroSocio = s.NroSocio,
                    NombreSocio = ObtenerNombreSocio(s),
                    Direccion = ObtenerDireccionParaBono(s),
                    ZonaTexto = ObtenerZonaTexto(s.Zona ?? Zona.Ninguna),
                    FrecuenciaPagoTexto = ObtenerFrecuenciaPagoTexto(s.FrecuenciaDePago),
                    MontoCuotaTexto = $"${s.MontoCuota:N0}"
                })
                .ToList();
        }
        catch
        {
            Bonos = new List<BonoImprimible>();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static bool DebeEmitirBono(FrecuenciaPago? frecuenciaPago, int mes)
    {
        return frecuenciaPago switch
        {
            FrecuenciaPago.Mensual => true,
            FrecuenciaPago.Trimestral => mes is 1 or 4 or 7 or 10,
            FrecuenciaPago.Semestral => mes is 1 or 7,
            FrecuenciaPago.Anual => mes == 1,
            _ => false
        };
    }

    private static string ObtenerFrecuenciaPagoTexto(FrecuenciaPago? frecuenciaPago)
    {
        return frecuenciaPago switch
        {
            FrecuenciaPago.Mensual => "Mensual",
            FrecuenciaPago.Trimestral => "Trimestral",
            FrecuenciaPago.Semestral => "Semestral",
            FrecuenciaPago.Anual => "Anual",
            _ => "Sin frecuencia"
        };
    }

    private static string ObtenerNombreSocio(Socio socio)
    {
        if (socio.Tipo == TipoSocio.Persona)
        {
            var apellido = (socio.Apellido ?? string.Empty).Trim();
            var nombre = (socio.Nombre ?? string.Empty).Trim();

            if (!string.IsNullOrWhiteSpace(apellido) && !string.IsNullOrWhiteSpace(nombre))
            {
                return $"{apellido}, {nombre}";
            }

            return string.IsNullOrWhiteSpace(apellido)
                ? (string.IsNullOrWhiteSpace(nombre) ? "-" : nombre)
                : apellido;
        }

        return string.IsNullOrWhiteSpace(socio.Nombre) ? "-" : socio.Nombre.Trim();
    }

    private static string ObtenerDireccionParaBono(Socio socio)
    {
        if (!string.IsNullOrWhiteSpace(socio.Direccion))
        {
            return socio.Direccion.Trim();
        }

        if (!string.IsNullOrWhiteSpace(socio.DireccionSecundaria))
        {
            return socio.DireccionSecundaria.Trim();
        }

        if (!string.IsNullOrWhiteSpace(socio.NotaAdicional))
        {
            return $"Nota: {socio.NotaAdicional.Trim()}";
        }

        return "Sin dirección";
    }

    private static Zona ConvertirZonaParametro(int zonaParam)
    {
        return zonaParam switch
        {
            1 => Zona.Zona1,
            2 => Zona.Zona2,
            3 => Zona.Zona3,
            4 => Zona.Zona4,
            5 => Zona.Zona5,
            _ when Enum.IsDefined(typeof(Zona), zonaParam) => (Zona)zonaParam,
            _ => Zona.Ninguna
        };
    }

    private static string ObtenerZonaTexto(Zona zona)
    {
        if (zona == Zona.Ninguna)
        {
            return "Sin zona";
        }

        var partes = new List<string>();

        if (zona.HasFlag(Zona.Zona1)) partes.Add("1");
        if (zona.HasFlag(Zona.Zona2)) partes.Add("2");
        if (zona.HasFlag(Zona.Zona3)) partes.Add("3");
        if (zona.HasFlag(Zona.Zona4)) partes.Add("4");
        if (zona.HasFlag(Zona.Zona5)) partes.Add("5");

        return partes.Count == 0 ? "Sin zona" : string.Join(", ", partes);
    }

    private static string ObtenerNombreMes(int mes)
    {
        if (mes is < 1 or > 12)
        {
            return "Mes inválido";
        }

        var cultura = new CultureInfo("es-AR");
        var nombreMes = cultura.DateTimeFormat.GetMonthName(mes);
        return cultura.TextInfo.ToTitleCase(nombreMes);
    }

    private static DateTime ObtenerFechaArgentina()
    {
        try
        {
            var zonaArgentina = TimeZoneInfo.FindSystemTimeZoneById("America/Argentina/Buenos_Aires");
            return TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, zonaArgentina);
        }
        catch
        {
            try
            {
                var zonaArgentina = TimeZoneInfo.FindSystemTimeZoneById("Argentina Standard Time");
                return TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, zonaArgentina);
            }
            catch
            {
                return DateTime.UtcNow.AddHours(-3);
            }
        }
    }

    private async Task DescargarPdf()
    {
        if (IsGenerating)
        {
            return;
        }

        IsGenerating = true;

        try
        {
            var nombreArchivo = $"BonosSocios_Zona{ZonaTexto.Replace(", ", "-")}_{MesTexto}_{AnioSeleccionado}_{FechaHoraArgentina:yyyyMMdd_HHmmss}.pdf";
            await JSRuntime.InvokeVoidAsync("pdfExport.generatePdfFast", "pdf-content", nombreArchivo, "portrait");
        }
        finally
        {
            IsGenerating = false;
        }
    }

    private async Task VistaPrevia()
    {
        if (IsGenerating)
        {
            return;
        }

        IsGenerating = true;

        try
        {
            var nombreArchivo = $"BonosSocios_Zona{ZonaTexto.Replace(", ", "-")}_{MesTexto}_{AnioSeleccionado}_{FechaHoraArgentina:yyyyMMdd_HHmmss}.pdf";
            await JSRuntime.InvokeVoidAsync("pdfExport.generatePdfPreviewFast", "pdf-content", nombreArchivo, "portrait");
        }
        finally
        {
            IsGenerating = false;
        }
    }
}
